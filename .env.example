# 访问用户名（仅首次启动时用于初始化，默认 "admin"）
# 首次启动后用户名存储在 data/auth.json，此变量将被忽略
# 之后通过设置页面修改用户名
ZFUNDPILOT_USERNAME=admin

# 访问密码（仅首次启动时用于初始化）
# 首次启动后密码以 SHA-256 哈希存储在 data/auth.json，此变量将被忽略
# 之后通过设置页面修改密码
# 留空则不启用密码认证（适合纯本地使用）
ZFUNDPILOT_PASSWORD=change_me_to_a_strong_password

# token 签名密钥（仅首次启动时用于初始化）
# 首次启动后自动生成随机密钥并存储在 data/auth.json，此变量将被忽略
# 留空则首次启动时自动生成
ZFUNDPILOT_SECRET=
