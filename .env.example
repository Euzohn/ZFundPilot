# 访问用户名（仅首次启动时用于初始化，默认 "admin"）
# 首次启动后用户名存储在 data/auth.json，此变量将被忽略
# 之后通过设置页面修改用户名
ZFUNDPILOT_USERNAME=admin

# 访问密码（仅首次启动时用于初始化）
# 首次启动后密码以 SHA-256 哈希存储在 data/auth.json，此变量将被忽略
# 之后通过设置页面修改密码
# 留空则不启用密码认证（适合纯本地使用）
ZFUNDPILOT_PASSWORD=change_me_to_a_strong_password

# token 签名密钥（仅首次启动时用于初始化）
# 首次启动后自动生成随机密钥并存储在 data/auth.json，此变量将被忽略
# 留空则首次启动时自动生成
ZFUNDPILOT_SECRET=

# 净值定时更新 cron 表达式（默认工作日 21:00）
# 格式：分 时 日 月 周
# 可在设置页面暂停/启用
ZFUNDPILOT_NAV_CRON=0 21 * * 1-5

# 反向代理信任网段（逗号分隔 CIDR，默认空 = 不信任任何代理）
# 仅在使用 Nginx/Caddy 等反代时配置，例如 "127.0.0.1/32,10.0.0.0/8"
# 误配会导致客户端可伪造 IP 绕过登录限流
ZFUNDPILOT_TRUSTED_PROXIES=
